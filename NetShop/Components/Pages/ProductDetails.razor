@page "/products/{Id:long}"
@rendermode InteractiveServer

<PageTitle>Product</PageTitle>

<!-- Hero -->
<div class="mx-auto flex min-h-screen max-w-[85rem] px-4 sm:px-6 lg:px-8">
    <!-- Grid -->
    <div class="grid gap-4 md:grid-cols-2 md:items-center md:gap-8 xl:gap-20">
        <div>
            <h1 class="block text-3xl font-bold text-gray-800 sm:text-4xl lg:text-6xl lg:leading-tight dark:text-white">@product.Name</h1>
            <p class="mt-3 text-lg text-gray-800 dark:text-neutral-400">@product.Description</p>

            <!-- Buttons -->
            <div class="mt-7 grid w-full gap-3 sm:inline-flex">
                <NavLink class="inline-flex cursor-pointer items-center justify-center gap-x-2 rounded-lg border border-transparent bg-blue-600 px-4 py-3 text-sm font-medium text-white hover:bg-blue-700 focus:bg-blue-700 focus:outline-hidden disabled:pointer-events-none disabled:opacity-50" href="@($"checkout/{product.StripePriceId}")">Buy</NavLink>
            </div>
            <!-- End Buttons -->
            <!-- Review -->
            <div class="mt-6 grid grid-cols-2 gap-x-5 lg:mt-10">
                <!-- Review -->
                <div class="py-5">
                    <p class="mt-3 text-sm text-gray-800 dark:text-neutral-200"><span class="font-bold">Price : </span>@product.Price</p>
                </div>
                <!-- End Review -->
                <!-- Review -->
                <div class="py-5">
                    <p class="mt-3 text-sm text-gray-800 dark:text-neutral-200"><span class="font-bold">Stock Quantity : </span>@product.StockQuantity</p>
                </div>
                <!-- End Review -->
            </div>
            <!-- End Review -->
        </div>
        <!-- End Col -->

        <div class="relative ms-4">
            @if (product.Images.Any())
            {
                <div class="flex h-full w-full items-center justify-center bg-gray-300 dark:bg-neutral-700">
                    <span class="text-sm font-medium text-gray-600 dark:text-neutral-300"> No image </span>
                </div>
            }
            else
            {
                <img class="w-full rounded-md" src="@product.Images.FirstOrDefault()" alt="product Image" />
            }
        </div>
        <!-- End Col -->
    </div>
    <!-- End Grid -->
</div>
<!-- End Hero -->
