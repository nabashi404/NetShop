@page "/dashboard/products/create"
@page "/dashboard/products/edit/{Id:long}"
@using NetShop.Enums
@rendermode InteractiveServer

<!-- Card Section -->
<div class="mx-auto max-w-2xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
    <!-- Card -->
    <div class="rounded-xl bg-white p-4 shadow-xs sm:p-7 dark:bg-neutral-900">
        <div class="mb-8 text-center">
            <h2 class="text-2xl font-bold text-gray-800 md:text-3xl dark:text-neutral-200">New Product</h2>
            <p class="my-1 text-sm text-gray-600 dark:text-neutral-400">Enter product details below to add it to your store</p>
        </div>

        @if (ProductDto.Images.Count() == 0)
        {
            <div class="flex h-52 w-full items-center justify-center rounded-md bg-gray-200 text-sm text-gray-500 dark:bg-neutral-700">
                <div class="flex w-full items-center justify-center rounded-sm">
                    <svg class="h-10 w-10 text-gray-200 dark:text-gray-600" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 18">
                        <path d="M18 0H2a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2Zm-5.5 4a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3Zm4.376 10.481A1 1 0 0 1 16 15H4a1 1 0 0 1-.895-1.447l3.5-7A1 1 0 0 1 7.468 6a.965.965 0 0 1 .9.5l2.775 4.757 1.546-1.887a1 1 0 0 1 1.618.1l2.541 4a1 1 0 0 1 .028 1.011Z" />
                    </svg>
                </div>
            </div>
        }
        else
        {
            <img src="@ProductDto.Images.FirstOrDefault()" alt="Product image" class="h-52 w-full rounded-md object-cover" />
        }

        <EditForm Model="@ProductDto" OnValidSubmit="@SaveAsync" FormName="ProductEditor">
            <DataAnnotationsValidator />
            <div class="py-6 first:pt-0 last:pb-0">
                <div class="mt-2 space-y-3">
                    <div class="sm:col-span-9">
                        <InputFile OnChange="HandleSelected" class="block w-full cursor-pointer rounded-lg border border-gray-200 shadow-sm file:me-4 file:border-0 file:bg-gray-50 file:bg-gray-100 file:px-4 file:py-2 focus:z-10 focus:border-blue-500 focus:ring-blue-500 disabled:pointer-events-none disabled:opacity-50 sm:text-sm dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-400 dark:file:bg-neutral-700 dark:file:text-neutral-400" accept="image/*" />
                    </div>

                    <ValidationMessage For="() => ProductDto.Status" class="text-red-600" />
                    <InputSelect @bind-Value="ProductDto.Status" class="block w-full rounded-lg border-gray-200 px-3 py-2 pe-9 text-sm focus:border-blue-500 focus:ring-blue-500 disabled:pointer-events-none disabled:opacity-50 dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-400 dark:placeholder-neutral-500 dark:focus:ring-neutral-600">
                        @foreach (ProductStatus status in Enum.GetValues(typeof(ProductStatus)))
                        {
                            <option value="@status">@status</option>
                        }
                    </InputSelect>

                    <ValidationMessage For="() => ProductDto.Name" class="text-red-600" />
                    <InputText @bind-Value="ProductDto.Name" type="text" class="block w-full rounded-lg border-gray-200 px-3 py-1.5 pe-11 shadow-2xs focus:border-blue-500 focus:ring-blue-500 disabled:pointer-events-none disabled:opacity-50 sm:py-2 sm:text-sm dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-400 dark:placeholder-neutral-500 dark:focus:ring-neutral-600" placeholder="Name" />

                    <ValidationMessage For="() => ProductDto.Description" class="text-red-600" />
                    <InputTextArea @bind-Value="ProductDto.Description" type="text" class="block w-full rounded-lg border-gray-200 px-3 py-1.5 pe-11 shadow-2xs focus:border-blue-500 focus:ring-blue-500 disabled:pointer-events-none disabled:opacity-50 sm:py-2 sm:text-sm dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-400 dark:placeholder-neutral-500 dark:focus:ring-neutral-600" placeholder="Description" rows="6" />

                    <ValidationMessage For="() => ProductDto.Price" class="text-red-600" />
                    <InputNumber @bind-Value="ProductDto.Price" type="number" step="0.01" class="block w-full rounded-lg border-gray-200 px-3 py-1.5 pe-11 pr-3 shadow-2xs focus:border-blue-500 focus:ring-blue-500 disabled:pointer-events-none disabled:opacity-50 sm:py-2 sm:text-sm dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-400 dark:placeholder-neutral-500 dark:focus:ring-neutral-600" placeholder="Price" />

                    <ValidationMessage For="() => ProductDto.Currency" class="text-red-600" />
                    <InputSelect @bind-Value="ProductDto.Currency" class="block w-full rounded-lg border-gray-200 px-3 py-1.5 shadow-2xs focus:border-blue-500 focus:ring-blue-500 sm:py-2 sm:text-sm dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-400">
                        @foreach (var currency in Enum.GetValues<Currency>())
                        {
                            <option value="@currency">@currency</option>
                        }
                    </InputSelect>

                    <ValidationMessage For="() => ProductDto.StockQuantity" class="text-red-600" />
                    <InputNumber @bind-Value="ProductDto.StockQuantity" type="number" class="block w-full rounded-lg border-gray-200 px-3 py-1.5 pe-11 pr-3 shadow-2xs focus:border-blue-500 focus:ring-blue-500 disabled:pointer-events-none disabled:opacity-50 sm:py-2 sm:text-sm dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-400 dark:placeholder-neutral-500 dark:focus:ring-neutral-600" placeholder="StockQuantity" />
                </div>
            </div>

            <div class="mt-5 flex justify-end gap-x-2">
                <button type="submit" class="inline-flex items-center gap-x-2 rounded-lg border border-transparent bg-blue-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-blue-700 focus:bg-blue-700 focus:outline-hidden disabled:pointer-events-none disabled:opacity-50 sm:py-2">Create</button>
            </div>
        </EditForm>
    </div>
    <!-- End Card -->
</div>
<!-- End Card Section -->
